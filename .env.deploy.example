# Copy this file to .env.deploy and fill real values.

DEPLOY_REMOTE_HOST=203.0.113.10
DEPLOY_REMOTE_USER=root
DEPLOY_REMOTE_PORT=22
DEPLOY_REMOTE_PATH=/var/www/html/mbelab.com/crm

# Optional: path to a dedicated deploy SSH key
# DEPLOY_SSH_KEY=/home/anais/.ssh/id_ed25519_mbelab_deploy

# Optional: local source path override
# DEPLOY_SOURCE_DIR=/home/anais/projects/mbelab/html/mbelab.com/crm

DEPLOY_OWNER=www-data
DEPLOY_GROUP=www-data

# Reload apache2 after push deploy (for mod_php OPCache refresh)
# 0: disabled by default (recommended when validate_timestamps=1)
# 1: reload apache2 after push deploy
DEPLOY_RELOAD_OPCACHE=0

# 0: apply perms only to changed files via rsync (default, fast)
# 1: run full chmod/chown scan over project after sync (slow)
DEPLOY_FULL_PERMS=0

# 0: do not sync config.inc.php (default, safer)
# 1: include config.inc.php in sync
DEPLOY_INCLUDE_CONFIG_INC=0

# 0: do not sync runtime/generated data (default, safer)
# 1: include runtime/generated data in sync (storage/, cache/, user_privileges/, etc.)
DEPLOY_INCLUDE_RUNTIME_DATA=0

# Note:
# runtime/generated data is excluded from sync unless DEPLOY_INCLUDE_RUNTIME_DATA=1
# In --dry-run mode script checks that remote dirs already exist:
# DEPLOY_REMOTE_PATH, DEPLOY_REMOTE_PATH/storage, DEPLOY_REMOTE_PATH/OperatorWayBill
